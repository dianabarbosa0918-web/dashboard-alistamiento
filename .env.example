# Copia estos nombres en Vercel: Settings > Environment Variables
# (No subas un archivo .env real a GitHub, esto es solo referencia)

MS_CLIENT_ID=87db862e-72d3-4cd4-a0ab-73e69fc194ae
MS_TENANT_ID=bfb53646-d4ba-4509-aabe-3c0ab4d79291
MS_CLIENT_SECRET=el-valor-del-secreto-que-copiaste-en-azure

# URL de callback: debe coincidir EXACTO con lo que registres en Azure
# Ejemplo si tu proyecto en Vercel se llama "dashboard-alistamiento":
REDIRECT_URI=https://dashboard-alistamiento.vercel.app/api/auth/callback

# Ruta del archivo dentro de tu OneDrive (relativa a la raíz de "Mis archivos")
# Ejemplo según tu captura de pantalla:
MS_FILE_PATH=Master Kaizen/Sedes/Circunvalar/Alistamiento Bitacora.xlsx

# Este NO lo pones tú manualmente al inicio: se genera visitando /api/auth/login
# una vez que el sitio esté desplegado, y luego lo pegas aquí.
MS_REFRESH_TOKEN=
